{
  "name": "discord-tts-attacher",
  "version": "0.1.0",
  "description": "OpenClaw plugin: synthesize Discord assistant replies to MP3 (Edge TTS) and attach them in a follow-up message.",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "check-version": "node scripts/check-version.mjs",
    "release": "bash scripts/prepare-release.sh",
    "sync-live": "bash scripts/sync-to-live-plugin.sh",
    "test:openclaw-resolve": "node scripts/test-openclaw-resolve.mjs"
  },
  "dependencies": {
    "node-edge-tts": "^1.2.10"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.28"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.28",
      "minGatewayVersion": "2026.3.28"
    },
    "build": {
      "openclawVersion": "2026.4.2",
      "pluginSdkVersion": "2026.4.2"
    }
  }
}
