# For the Cursor / dev repository only. Not copied into ~/.openclaw/extensions (see sync-to-live-plugin.sh).

# Build output (npm run release) — not committed; generate before zip or ClawHub upload
release/

# Dependencies & secrets
node_modules/
.env
.env.*

# Cursor — ignore editor state under .cursor/; keep rules for shared AI/project guidance
.cursor/**
!.cursor/rules/
!.cursor/rules/**

# VS Code / Cursor workspace user overrides (optional folder)
.vscode/

# Logs & debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# TTS artifacts (also land under outputDir; ignore if ever committed from workspace)
*.mp3
*.done.json
